---
// src/layouts/Layout.astro
import '@fontsource/manrope/400.css';
import '@fontsource/manrope/500.css';
import '@fontsource/manrope/800.css';
import '@fontsource/unbounded/400.css';
import '@fontsource/unbounded/700.css';
import '@fontsource/unbounded/900.css';

import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Background from '../components/ui/Background.astro';
import ScrollCompanion from '../components/ui/ScrollCompanion.astro';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  image?: string;
}

const {
  title = 'Rerowros — продуктовый разработчик',
  description = 'Разрабатываю веб-продукты, автоматизацию и AI-инструменты. Пишу о разработке, собственных проектах и практических экспериментах.',
  pathname = '/',
  image = '/favicon.svg',
} = Astro.props;

const normalizedPathname = pathname.startsWith('/') ? pathname : `/${pathname}`;
const cleanPathname = normalizedPathname.endsWith('/')
  ? normalizedPathname
  : `${normalizedPathname}/`;

const canonicalImage = new URL(image, Astro.site || 'https://rerowros.ru').toString();
const currentLang = Astro.currentLocale || 'ru';
const isBlogArticle = /^\/(?:en\/)?blog\/(?!tag(?:\/|$))[^/]+\/?$/.test(Astro.url.pathname);

const pageTransition = {
  forwards: {
    old: { name: 'page-exit-forward', duration: '180ms', easing: 'cubic-bezier(.4,0,1,1)' },
    new: { name: 'page-enter-forward', duration: '420ms', easing: 'cubic-bezier(.16,1,.3,1)' },
  },
  backwards: {
    old: { name: 'page-exit-back', duration: '180ms', easing: 'cubic-bezier(.4,0,1,1)' },
    new: { name: 'page-enter-back', duration: '420ms', easing: 'cubic-bezier(.16,1,.3,1)' },
  },
};
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth" transition:name="root" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark light" />
    <meta name="darkreader-lock" />

    <meta
      name="keywords"
      content="Product Engineering, AI Development, Web Products, Automation, TypeScript, Python, Astro, React, продуктовая разработка, AI-инструменты, автоматизация"
    />

    <title>{title}</title>

    <link rel="canonical" href={`https://rerowros.ru${cleanPathname}`} />
    <meta property="og:locale" content={currentLang === 'ru' ? 'ru_RU' : 'en_US'} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://rerowros.ru${cleanPathname}`} />
    <meta property="og:image" content={canonicalImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@rerowros" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={canonicalImage} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'Person',
            name: 'Ярослав (Rerowros)',
            url: 'https://rerowros.ru/',
            sameAs: ['https://t.me/rerowros', 'https://github.com/Rerowros'],
            jobTitle: 'Product Engineer and Full-Stack Developer',
            makesOffer: [
              {
                '@type': 'Offer',
                itemOffered: {
                  '@type': 'Service',
                  name: 'Разработка цифровых продуктов',
                },
              },
              {
                '@type': 'Offer',
                itemOffered: {
                  '@type': 'Service',
                  name: 'AI-функции и автоматизация',
                },
              },
            ],
            knowsAbout: ['Product Engineering', 'Artificial Intelligence', 'TypeScript', 'Python', 'React', 'Astro', 'Automation', 'SEO experiments'],
            description: 'Разработчик цифровых продуктов, веб-приложений, автоматизации и AI-инструментов.',
          },
          {
            '@type': 'WebSite',
            name: 'Rerowros — продукты, разработка и блог',
            url: 'https://rerowros.ru/',
            potentialAction: {
              '@type': 'SearchAction',
              target: 'https://rerowros.ru/blog/?q={search_term_string}',
              'query-input': 'required name=search_term_string',
            },
          },
        ],
      })}
    />
    <link rel="icon" type="image/png" href="/favicon.svg" />

    <meta name="view-transition" content="same-origin" />
    <ClientRouter />

    <script>
      import { applyTheme } from '../scripts/theme';
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <script is:inline>
      (function (m, e, t, r, i, k, a) {
        m[i] =
          m[i] ||
          function () {
            (m[i].a = m[i].a || []).push(arguments);
          };
        m[i].l = 1 * new Date();
        for (var j = 0; j < document.scripts.length; j++) {
          if (document.scripts[j].src === r) {
            return;
          }
        }
        ((k = e.createElement(t)),
          (a = e.getElementsByTagName(t)[0]),
          (k.async = 1),
          (k.src = r),
          a.parentNode.insertBefore(k, a));
      })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js', 'ym');

      window['ym'](106091669, 'init', {
        clickmap: true,
        trackLinks: true,
        accurateTrackBounce: true,
        webvisor: true,
      });
    </script>

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-E3GFTGVKJP"></script>
    <script is:inline>
      window['dataLayer'] = window['dataLayer'] || [];
      function gtag() {
        window['dataLayer'].push(arguments);
      }

      gtag('js', new Date());
      gtag('config', 'G-E3GFTGVKJP');
    </script>

    <script>
      const YM_ID = 106091669;
      const GA_ID = 'G-E3GFTGVKJP';

      document.addEventListener('astro:page-load', () => {
        const currentUrl = window.location.href;
        const w = window as any;
        if (typeof w['ym'] === 'function') {
          w['ym'](YM_ID, 'hit', currentUrl);
        }
        if (typeof w['gtag'] === 'function') {
          w['gtag']('config', GA_ID, {
            page_path: window.location.pathname,
            page_title: document.title,
            page_location: currentUrl,
          });
        }
      });
    </script>
  </head>
  <body class="selection:bg-primary/30 font-['Inter'] antialiased">
    <noscript>
      <div>
        <img
          src="https://mc.yandex.ru/watch/106091669"
          style="position:absolute; left:-9999px;"
          alt=""
        />
      </div>
    </noscript>

    <div transition:persist>
      <Background />
    </div>

    {!isBlogArticle && (
      <div transition:name="byte-companion" transition:animate="none">
        <ScrollCompanion lang={currentLang} />
      </div>
    )}

    <main
      class="relative z-10 w-full overflow-x-clip"
      transition:name="page-content"
      transition:animate={pageTransition}
    >
      <slot />
    </main>

    <script>
      // --- ЛОГИКА СОХРАНЕНИЯ СКРОЛЛА ПРИ СМЕНЕ ЯЗЫКА ---

      // 1. Перед началом перехода
      document.addEventListener('astro:before-preparation', (event) => {
        const fromPath = window.location.pathname;
        const toPath = new URL(event.to).pathname;

        // Функция нормализации пути (убираем /en/ и слеши)
        const normalize = (p: string) =>
          p
            .replace(/^\/en\//, '/')
            .replace(/\/$/, '')
            .replace(/^\//, '');

        // Если это одна и та же страница (просто смена языка)
        if (normalize(fromPath) === normalize(toPath)) {
          // Сохраняем позицию
          sessionStorage.setItem('lang-scroll-y', window.scrollY.toString());
          // Сохраняем флаг, что это именно смена языка (чтобы не путать с кнопкой "Назад")
          sessionStorage.setItem('is-lang-switch', 'true');
        }
      });

      // 2. Сразу после подмены DOM, но до отрисовки
      document.addEventListener('astro:after-swap', () => {
        const savedY = sessionStorage.getItem('lang-scroll-y');
        const isLangSwitch = sessionStorage.getItem('is-lang-switch');

        if (savedY && isLangSwitch) {
          // Мгновенно восстанавливаем скролл без анимации
          window.scrollTo({ top: parseInt(savedY), behavior: 'instant' });

          // Чистим хранилище
          sessionStorage.removeItem('lang-scroll-y');
          sessionStorage.removeItem('is-lang-switch');
        }
      });

      let cleanupScrollObserver = () => {};

      function initScrollObserver() {
        cleanupScrollObserver();
        const observer = new IntersectionObserver(
          (entries) => {
            window.requestAnimationFrame(() => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  observer.unobserve(entry.target);
                }
              });
            });
          },
          {
            threshold: 0.1,
            rootMargin: '50px',
          }
        );

        const animatedElements = document.querySelectorAll('.scroll-animate');
        animatedElements.forEach((element) => observer.observe(element));
        cleanupScrollObserver = () => observer.disconnect();
      }

      document.addEventListener('astro:page-load', () => {
        initScrollObserver();
      });
      document.addEventListener('astro:before-swap', () => cleanupScrollObserver());
    </script>
  </body>

</html>
