---
import type { MarkdownHeading } from 'astro';
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Layout from './Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import TelegramIcon from '../components/icons/TelegramIcon.astro';
import { getReadingTime } from '../scripts/reading-time';
import '../styles/blog-post.css';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: MarkdownHeading[];
  lang: 'ru' | 'en';
}

const { post, headings, lang } = Astro.props;
const isRu = lang === 'ru';
const cleanSlug = post.slug.replace(/^(ru|en)\//, '');
const alternateLang = lang === 'ru' ? 'en' : 'ru';
const currentUrl = `https://rerowros.ru${getRelativeLocaleUrl(lang, `blog/${cleanSlug}`)}`;
const alternateUrl = `https://rerowros.ru${getRelativeLocaleUrl(alternateLang, `blog/${cleanSlug}`)}`;
const ogImageUrl = `/blog/${cleanSlug}/og.png`;
const readingTime = post.data.readingTime || getReadingTime(post.body);
const postType = post.data.postType || 'analysis';
const typeLabels = {
  ru: { analysis: 'Разбор', experiment: 'Эксперимент', note: 'Заметка', 'build-log': 'Build log' },
  en: { analysis: 'Analysis', experiment: 'Experiment', note: 'Note', 'build-log': 'Build log' },
};
const typeLabel = typeLabels[lang][postType];
const trustDate = post.data.verifiedAt || post.data.lastModified;
const allPosts = (await getCollection('blog', ({ id }) => id.startsWith(`${lang}/`)))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const articleHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const showToc = postType !== 'note' && articleHeadings.length > 0;
const relatedPosts = allPosts
  .filter((entry) => entry.id !== post.id)
  .map((entry) => ({ entry, score: entry.data.tags.filter((tag) => post.data.tags.includes(tag)).length }))
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score || b.entry.data.pubDate.valueOf() - a.entry.data.pubDate.valueOf())
  .slice(0, 2)
  .map(({ entry }) => entry);
const seriesPosts = post.data.series
  ? allPosts
      .filter((entry) => entry.data.series?.name === post.data.series?.name)
      .sort((a, b) => (a.data.series?.part || 0) - (b.data.series?.part || 0))
  : [];
const seriesIndex = seriesPosts.findIndex((entry) => entry.id === post.id);
const seriesPrev = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
const seriesNext = seriesIndex >= 0 && seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;
const postHref = (entry: CollectionEntry<'blog'>) => getRelativeLocaleUrl(lang, `blog/${entry.slug.replace(/^(ru|en)\//, '')}`);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.excerpt || post.data.description,
  image: ogImageUrl,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.lastModified || post.data.pubDate).toISOString(),
  author: { '@type': 'Person', name: 'Rerowros', url: 'https://rerowros.ru' },
  mainEntityOfPage: currentUrl,
};
---

<Layout
  title={`${post.data.title} | Rerowros`}
  description={post.data.excerpt || post.data.description || post.data.title}
  pathname={getRelativeLocaleUrl(lang, `blog/${cleanSlug}`)}
  image={ogImageUrl}
>
  <link rel="alternate" hreflang={lang} href={currentUrl} />
  <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <Header />
  <div class="article-progress" aria-hidden="true"><span data-reading-progress></span></div>

  <article class="article-page" data-post-type={postType}>
    <header class="article-hero">
      <div class="article-hero-nav">
        <a href={getRelativeLocaleUrl(lang, 'blog/')}>← {isRu ? 'Все материалы' : 'All posts'}</a>
        <a href={getRelativeLocaleUrl(alternateLang, `blog/${cleanSlug}`)}>{isRu ? 'Read in English' : 'Читать на русском'}</a>
      </div>
      <div class="article-meta">
        <strong>{typeLabel}</strong>
        <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString(isRu ? 'ru-RU' : 'en-US', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
        {readingTime && <span>{readingTime} {isRu ? 'мин чтения' : 'min read'}</span>}
        {trustDate && <span>{post.data.verifiedAt ? (isRu ? 'Проверено' : 'Verified') : (isRu ? 'Обновлено' : 'Updated')} {trustDate.toLocaleDateString(isRu ? 'ru-RU' : 'en-US')}</span>}
        {post.data.versionLabel && <span>{post.data.versionLabel}</span>}
        {post.data.series && <span>{post.data.series.name} · {post.data.series.part}/{post.data.series.total}</span>}
      </div>
      <h1>{post.data.title}</h1>
      {(post.data.excerpt || post.data.description) && <p class="article-excerpt">{post.data.excerpt || post.data.description}</p>}
      <div class="article-tags">
        {post.data.tags.map((tag) => <a href={getRelativeLocaleUrl(lang, `blog/tag/${tag}/`)}>#{tag}</a>)}
      </div>
      <div class="article-verification">
        <span>{isRu ? 'Нашли неточность?' : 'Found an inaccuracy?'}</span>
        <a href="https://t.me/Rerowros" target="_blank" rel="noopener noreferrer">{isRu ? 'Сообщить об ошибке' : 'Report an issue'} ↗</a>
      </div>
      {postType === 'experiment' && (
        <div class="article-method" aria-label={isRu ? 'Структура эксперимента' : 'Experiment structure'}>
          {[isRu ? 'Гипотеза' : 'Hypothesis', isRu ? 'Действие' : 'Action', isRu ? 'Наблюдение' : 'Observation', isRu ? 'Вывод' : 'Conclusion'].map((item, index) => <span><b>0{index + 1}</b>{item}</span>)}
        </div>
      )}
      {postType === 'build-log' && (
        <div class="article-method" aria-label={isRu ? 'Структура build log' : 'Build log structure'}>
          {[isRu ? 'Цель' : 'Goal', isRu ? 'Ограничения' : 'Constraints', isRu ? 'Решение' : 'Decision', isRu ? 'Следующая итерация' : 'Next iteration'].map((item, index) => <span><b>0{index + 1}</b>{item}</span>)}
        </div>
      )}
      {post.data.coverImage && (
        <div class="article-cover">
          <Image src={post.data.coverImage} alt={post.data.title} width={1600} height={900} quality={88} priority />
        </div>
      )}
    </header>

    {showToc && (
      <div class="article-mobile-toc-wrap">
        <button class="article-toc-toggle" type="button" aria-expanded="false" aria-controls="article-mobile-toc" data-mobile-toc-open>
          <span>{isRu ? 'В статье' : 'In this article'}</span><b>{articleHeadings.length}</b>
        </button>
        <div id="article-mobile-toc" class="article-mobile-toc" hidden data-mobile-toc>
          <button class="article-mobile-toc-backdrop" type="button" aria-label={isRu ? 'Закрыть оглавление' : 'Close contents'} data-mobile-toc-close></button>
          <div class="article-mobile-toc-panel">
            <header><p>{isRu ? 'В статье' : 'In this article'}</p><button type="button" data-mobile-toc-close>×</button></header>
            <nav>{articleHeadings.map((heading) => <a class:list={{ 'is-sub': heading.depth === 3 }} href={`#${heading.slug}`} data-toc-id={heading.slug}>{heading.text}</a>)}</nav>
          </div>
        </div>
      </div>
    )}

    <div class="article-layout">
      <main class="article-main">
        {post.data.tldr && (
          <details class="article-summary">
            <summary><span>TL;DR</span>{isRu ? 'Коротко о главном' : 'Quick summary'}<b aria-hidden="true">＋</b></summary>
            <p>{post.data.tldr}</p>
          </details>
        )}
        <div class="article-content"><slot /></div>

        {(post.data.series ? Boolean(seriesPrev || seriesNext) : relatedPosts.length > 0) && (
          <nav class="article-neighbors" aria-label={isRu ? 'Другие статьи' : 'More articles'}>
            {post.data.series ? (
              <>
                {seriesPrev ? <a href={postHref(seriesPrev)}><span>{isRu ? 'Предыдущая часть' : 'Previous part'}</span><strong>{seriesPrev.data.title}</strong></a> : <i></i>}
                {seriesNext && <a href={postHref(seriesNext)}><span>{isRu ? 'Следующая часть' : 'Next part'}</span><strong>{seriesNext.data.title}</strong></a>}
              </>
            ) : relatedPosts.map((entry) => <a href={postHref(entry)}><span>{isRu ? 'По теме' : 'Related'}</span><strong>{entry.data.title}</strong></a>)}
          </nav>
        )}

        <section class="article-contact">
          <div>
            <h2>{isRu ? 'Продолжение — в канале.' : 'More in the channel.'}</h2>
            <span>{isRu ? 'Короткие заметки, новые материалы и то, что сейчас собираю. По проектам и идеям можно написать лично.' : 'Short notes, new writing, and what I am currently building. You can also message me directly about projects and ideas.'}</span>
          </div>
          <div class="article-contact-links">
            <a href={post.data.discussionUrl || 'https://t.me/rerowroslog'} target="_blank" rel="noopener noreferrer"><TelegramIcon class="h-5 w-5" /> {post.data.discussionUrl ? (isRu ? 'Обсудить статью' : 'Discuss') : (isRu ? 'Канал' : 'Channel')}</a>
            <a href="https://t.me/Rerowros" target="_blank" rel="noopener noreferrer">{isRu ? 'Написать' : 'Message'}</a>
          </div>
        </section>
      </main>

      <aside class="article-aside">
        {showToc && (
          <nav class="article-toc" aria-label={isRu ? 'Содержание' : 'Contents'}>
            <p>{isRu ? 'В статье' : 'In this article'}</p>
            {articleHeadings.map((heading) => <a class:list={{ 'is-sub': heading.depth === 3 }} href={`#${heading.slug}`} data-toc-id={heading.slug}>{heading.text}</a>)}
          </nav>
        )}
        <div class="article-share">
          <span>{isRu ? 'Поделиться' : 'Share'}</span>
          <a href={`https://t.me/share/url?url=${encodeURIComponent(currentUrl)}&text=${encodeURIComponent(post.data.title)}`} target="_blank">Telegram</a>
          <button type="button" data-copy-link={currentUrl}>{isRu ? 'Скопировать ссылку' : 'Copy link'}</button>
        </div>
      </aside>
    </div>
  </article>
  <Footer />

  <script>
    let cleanupArticlePage = () => {};
    function initArticlePage() {
      cleanupArticlePage();
      const progress = document.querySelector<HTMLElement>('[data-reading-progress]');
      if (!progress) return;
      const controller = new AbortController();
      let frame = 0;
      const updateProgress = () => {
        if (frame) return;
        frame = requestAnimationFrame(() => {
          frame = 0;
          if (!progress) return;
          const available = document.documentElement.scrollHeight - window.innerHeight;
          progress.style.transform = `scaleX(${available > 0 ? Math.min(1, window.scrollY / available) : 0})`;
        });
      };
      window.addEventListener('scroll', updateProgress, { passive: true, signal: controller.signal });
      updateProgress();

      const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-id]'));
      const observer = new IntersectionObserver((entries) => {
        const active = entries.filter((entry) => entry.isIntersecting).sort((a, b) => Math.abs(a.boundingClientRect.top) - Math.abs(b.boundingClientRect.top))[0];
        if (!(active?.target instanceof HTMLElement)) return;
        tocLinks.forEach((link) => link.classList.toggle('is-active', link.dataset.tocId === active.target.id));
      }, { rootMargin: '-18% 0px -72% 0px', threshold: 0 });
      document.querySelectorAll<HTMLElement>('.article-content h2, .article-content h3').forEach((heading) => observer.observe(heading));

      document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((button) => {
        button.addEventListener('click', async () => {
          await navigator.clipboard.writeText(button.dataset.copyLink || window.location.href);
          button.textContent = document.documentElement.lang === 'ru' ? 'Скопировано' : 'Copied';
        }, { signal: controller.signal });
      });

      document.querySelectorAll<HTMLElement>('.article-content pre').forEach((pre) => {
        if (pre.parentElement?.classList.contains('article-code-shell')) return;
        const languageClass = `${pre.className} ${pre.querySelector('code')?.className || ''}`.match(/language-([\w-]+)/)?.[1];
        const shell = document.createElement('div');
        shell.className = 'article-code-shell';
        const bar = document.createElement('div');
        bar.className = 'article-code-bar';
        const label = document.createElement('span');
        label.textContent = pre.dataset.language || languageClass || 'code';
        const copy = document.createElement('button');
        copy.type = 'button';
        copy.textContent = document.documentElement.lang === 'ru' ? 'Копировать' : 'Copy';
        bar.append(label, copy);
        pre.parentNode?.insertBefore(shell, pre);
        shell.append(bar, pre);
        copy.addEventListener('click', async () => {
          await navigator.clipboard.writeText(pre.textContent || '');
          copy.textContent = document.documentElement.lang === 'ru' ? 'Скопировано' : 'Copied';
        }, { signal: controller.signal });
      });

      const mobileToc = document.querySelector<HTMLElement>('[data-mobile-toc]');
      const openButton = document.querySelector<HTMLButtonElement>('[data-mobile-toc-open]');
      const closeButtons = document.querySelectorAll<HTMLButtonElement>('[data-mobile-toc-close]');
      const setMobileToc = (open: boolean) => {
        if (!mobileToc || !openButton) return;
        mobileToc.hidden = !open;
        openButton.setAttribute('aria-expanded', String(open));
        document.body.style.overflow = open ? 'hidden' : '';
      };
      openButton?.addEventListener('click', () => setMobileToc(true), { signal: controller.signal });
      closeButtons.forEach((button) => button.addEventListener('click', () => setMobileToc(false), { signal: controller.signal }));
      mobileToc?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setMobileToc(false), { signal: controller.signal }));
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && mobileToc && !mobileToc.hidden) setMobileToc(false);
      }, { signal: controller.signal });

      cleanupArticlePage = () => {
        controller.abort();
        observer.disconnect();
        if (frame) cancelAnimationFrame(frame);
        document.body.style.overflow = '';
      };
    }
    document.addEventListener('astro:page-load', initArticlePage);
    document.addEventListener('astro:before-swap', () => cleanupArticlePage());
  </script>
</Layout>
