---
// src/pages/blog/index.astro
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import { fade } from 'astro:transitions';
import { getRelativeLocaleUrl } from 'astro:i18n';

const currentLang = Astro.currentLocale || 'ru';

// Получаем все посты и сортируем
const posts = (await getCollection('blog', ({ id }) => id.startsWith('en/')))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title={currentLang === 'ru' ? 'Блог | Rerowros' : 'Blog | Rerowros'}
  description={currentLang === 'ru' ? 'Статьи об инженерии, сетевой безопасности и веб-разработке.' : 'Engineering, Network Security, and Web Development articles.'}
  pathname={getRelativeLocaleUrl(currentLang, 'blog')}
>
  <Header />
<main
  class="container mx-auto min-h-screen px-4 pt-32 pb-20"
  transition:animate={fade({ duration: '0.2s' })}
>
  <div class="mx-auto max-w-6xl"> <!-- Увеличил ширину для сетки -->
    
    <div class="mb-12 text-center">
      <h1 class="font-cinzel text-glow mb-4 text-4xl font-extrabold md:text-6xl">
        <span class="animate-gradient bg-300% bg-gradient-to-r from-white via-[var(--color-primary)] to-white bg-clip-text text-transparent">
          Engineering Log
        </span>
      </h1>
      <p class="text-xl text-[var(--color-muted-foreground)]">
        {currentLang === 'ru' ? 'Сетевая безопасность / Анализ протоколов / Низкоуровневая инженерия' : 'Network Security / Protocol Analysis / Low-level Engineering'}
      </p>
    </div>

    <!-- СЕКЦИЯ 1: КАРТОЧКИ КАТЕГОРИЙ (Твой скетч) -->
    <div class="mb-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      
      <!-- Карточка 1: Аналитика (TSPU) -->
      <a href={getRelativeLocaleUrl(currentLang, 'blog/tag/DPI/')} class="group relative overflow-hidden rounded-3xl border border-[var(--color-border)] bg-[var(--color-card)] p-8 transition-all hover:border-red-500/50 hover:shadow-lg hover:shadow-red-500/10">
        <div class="absolute inset-0 bg-gradient-to-br from-red-500/5 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
        <div class="relative z-10 flex h-full flex-col justify-between">
          <div>
            <div class="mb-4 inline-flex rounded-lg bg-red-500/10 p-3 text-red-500">
              <!-- Иконка "Глаз" или "Радар" -->
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
            </div>
            <h3 class="font-cinzel mb-2 text-2xl font-bold text-white">Deep Analysis</h3>
            <p class="text-sm text-[var(--color-muted-foreground)]">
              {currentLang === 'ru' ? 'Как работает цензура. Разбор ТСПУ, DPI, Active Probing и ML-анализа трафика.' : 'How censorship works. Analysis of TSPU, DPI, Active Probing and ML traffic analysis.'}
            </p>
          </div>
          <div class="mt-8 flex items-center text-sm font-bold text-red-400">
            <span>{currentLang === 'ru' ? 'Исследовать DPI' : 'Explore DPI'}</span>
            <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </div>
        </div>
      </a>

      <!-- Карточка 2: Протоколы (Practice) -->
      <a href={getRelativeLocaleUrl(currentLang, 'blog/tag/Networking/')} class="group relative overflow-hidden rounded-3xl border border-[var(--color-border)] bg-[var(--color-card)] p-8 transition-all hover:border-[var(--color-primary)] hover:shadow-lg hover:shadow-[var(--color-primary)]/10">
        <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/5 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
        <div class="relative z-10 flex h-full flex-col justify-between">
          <div>
            <div class="mb-4 inline-flex rounded-lg bg-[var(--color-primary)]/10 p-3 text-[var(--color-primary)]">
              <!-- Иконка "Сеть" -->
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
            </div>
            <h3 class="font-cinzel mb-2 text-2xl font-bold text-white">Protocols & Tools</h3>
            <p class="text-sm text-[var(--color-muted-foreground)]">
              {currentLang === 'ru' ? 'Практика. Настройка XHTTP, Reality, VLESS. Оптимизация сетевого стека.' : 'Practice. Configuring XHTTP, Reality, VLESS. Network stack optimization.'}
            </p>
          </div>
          <div class="mt-8 flex items-center text-sm font-bold text-[var(--color-primary)]">
            <span>{currentLang === 'ru' ? 'Смотреть решения' : 'View Solutions'}</span>
            <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </div>
        </div>
      </a>

      <!-- Карточка 3: База (Fundamentals) -->
      <a href={getRelativeLocaleUrl(currentLang, 'blog/network-fundamentals/')} class="group relative overflow-hidden rounded-3xl border border-[var(--color-border)] bg-[var(--color-card)] p-8 transition-all hover:border-emerald-500/50 hover:shadow-lg hover:shadow-emerald-500/10 md:col-span-2 lg:col-span-1">
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
        <div class="relative z-10 flex h-full flex-col justify-between">
          <div>
            <div class="mb-4 inline-flex rounded-lg bg-emerald-500/10 p-3 text-emerald-500">
              <!-- Иконка "Книга" -->
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            </div>
            <h3 class="font-cinzel mb-2 text-2xl font-bold text-white">Fundamentals</h3>
            <p class="text-sm text-[var(--color-muted-foreground)]">
              {currentLang === 'ru' ? 'База сетей. TCP/IP, Handshakes, Шифрование. Для новичков.' : 'Network fundamentals. TCP/IP, Handshakes, Encryption. For beginners.'}
            </p>
          </div>
          <div class="mt-8 flex items-center text-sm font-bold text-emerald-400">
            <span>{currentLang === 'ru' ? 'Начать здесь' : 'Start Here'}</span>
            <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </div>
        </div>
      </a>

    </div>

    <!-- СЕКЦИЯ 2: СПИСОК СТАТЕЙ (Твой старый дизайн, но компактнее) -->
    <div class="relative">
      <h2 class="font-cinzel mb-8 text-2xl font-bold text-white">
        {currentLang === 'ru' ? 'Последние публикации' : 'Latest Articles'}
      </h2>
      
      <!-- Тут используем grid для статей, чтобы было как на скетче внизу -->
      <div class="grid gap-6 md:grid-cols-2"> <!-- Изменил на grid -->
        {
          posts.map((post, index) => (
            <div
              class="scroll-animate group glass-card relative flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] p-6 transition-all hover:border-[var(--color-primary)] hover:shadow-[var(--color-primary)]/10 hover:shadow-lg"
              style={`transition-delay: ${index * 50}ms`}
            >
              <!-- ... Твой старый код карточки ... -->
              <div class="relative z-10 mb-4 flex items-center justify-between gap-4">
                 <div class="flex gap-2">
                    {post.data.tags.slice(0, 2).map(tag => ( // Ограничил до 2 тегов
                        <span class="rounded border border-[var(--color-border)] px-2 py-0.5 text-[10px] text-[var(--color-muted-foreground)]">#{tag}</span>
                    ))}
                 </div>
                 <time class="font-mono text-[10px] text-[var(--color-muted-foreground)]">
                    {post.data.pubDate.toLocaleDateString(currentLang === 'ru' ? 'ru-RU' : 'en-US')}
                 </time>
              </div>

              <a href={getRelativeLocaleUrl(currentLang, `blog/${post.slug.replace(/^en\//, '')}`)} class="relative z-10 mb-3 block grow">
                <h2 class="font-cinzel text-xl font-bold leading-tight transition-colors group-hover:text-[var(--color-primary)]">
                  {post.data.title}
                </h2>
              </a>
              
              <p class="mb-4 line-clamp-2 text-sm text-[var(--color-muted-foreground)]">
                  {post.data.excerpt}
              </p>

              <div class="mt-auto pt-4 border-t border-[var(--color-border)]/50">
                 <a href={getRelativeLocaleUrl(currentLang, `blog/${post.slug.replace(/^en\//, '')}`)} class="text-xs font-bold text-[var(--color-primary)] uppercase tracking-wider">
                   {currentLang === 'ru' ? 'Читать статью' : 'Read Article'} &rarr;
                 </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>

  </div>
</main>

  <Footer />
</Layout>

<style>
  .bg-300\% {
    background-size: 300% auto;
  }
  .animate-gradient {
    animation: gradient 8s ease infinite;
  }
  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
</style>
