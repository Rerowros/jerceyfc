---
import { getCollection } from 'astro:content';
import BlogTagPage from '../../../components/pages/BlogTagPage.astro';

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog', ({ id }) => id.startsWith('ru/'))).filter((post) => !post.data.draft);
  const tags = [...new Set(allPosts.flatMap((post) => post.data.tags))];
  return tags.map((tag) => ({ params: { tag }, props: { tag, posts: allPosts.filter((post) => post.data.tags.includes(tag)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()) } }));
}

const { tag, posts } = Astro.props;
---

<BlogTagPage tag={tag} posts={posts} lang="ru" />
