---
// src/pages/blog/[...slug].astro
import { getCollection } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import Callout from '../../components/content/Callout.astro';
import References from '../../components/content/References.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ id }) => id.startsWith('ru/'));
  return posts.map((post) => {
    const slug = post.slug.replace(/^ru\//, '');
    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
---

<BlogPostLayout post={post} headings={headings} lang="ru">
  <!-- Передаем компоненты, так как они используются внутри MDX -->
  <Content components={{ Callout, References }} />
</BlogPostLayout>
