---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  project: CollectionEntry<'projects'>;
  index?: number;
}

const { project, index = 99 } = Astro.props;
const { data, id } = project;
const currentLang = Astro.currentLocale || 'ru';
const slug = id.replace(/^(ru|en)\//, '').replace(/\.mdx$/, '');
---

<a class="project-card" href={getRelativeLocaleUrl(currentLang, `projects/${slug}/`)}>
  <div class="project-card-media">
    {data.coverImage ? (
      <Image
        src={data.coverImage}
        alt={data.title}
        width={720}
        height={460}
        format="webp"
        quality={75}
        priority={index < 3}
        class="project-card-image"
      />
    ) : (
      <div class="project-card-placeholder" aria-hidden="true">
        <span>{data.type}</span>
      </div>
    )}
    {data.featured && <span class="project-card-featured">Selected</span>}
  </div>

  <div class="project-card-body">
    <p>{data.type} · {data.status}</p>
    <h3>{data.title}</h3>
    <div>{data.description}</div>
    <footer>
      <span>{data.tags.slice(0, 3).join(' · ')}</span>
      <b aria-hidden="true">↗</b>
    </footer>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    height: 100%;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 1.75rem;
    background: var(--color-card);
    color: var(--color-foreground);
    transition: border-color 180ms ease, transform 180ms ease, border-radius 180ms ease, box-shadow 180ms ease;
  }

  .project-card:hover {
    border-color: var(--color-foreground);
    border-radius: 2.35rem 1.35rem 2.35rem 1.35rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.14);
    transform: translateY(-4px) rotate(-0.35deg);
  }

  .project-card-media {
    position: relative;
    height: 220px;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-muted);
  }

  .project-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.8);
  }

  .project-card-placeholder {
    display: flex;
    height: 100%;
    align-items: flex-end;
    padding: 1.25rem;
    background: linear-gradient(145deg, var(--color-muted), var(--color-card));
  }

  .project-card-placeholder span,
  .project-card-featured,
  .project-card-body > p {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-card-featured {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.35rem 0.55rem;
    border-radius: 0.65rem;
    background: var(--color-primary);
    color: #11110f;
    font-weight: 800;
  }

  .project-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.5rem;
  }

  .project-card-body > p {
    margin: 0 0 1rem;
    color: var(--color-muted-foreground);
  }

  .project-card-body h3 {
    margin: 0 0 0.75rem;
    font-family: 'Manrope', sans-serif;
    font-size: 1.35rem;
    font-weight: 650;
    letter-spacing: -0.035em;
  }

  .project-card-body > div {
    color: var(--color-muted-foreground);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .project-card-body footer {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 1.5rem;
    color: var(--color-muted-foreground);
    font-size: 0.68rem;
    line-height: 1.5;
  }

  .project-card-body footer b {
    color: var(--color-primary);
    font-size: 1rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card { transition: none; }
  }
</style>
