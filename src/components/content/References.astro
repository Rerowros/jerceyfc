---
const currentLang = Astro.currentLocale || 'ru';
interface Source { id: string | number; title: string; url: string; sourceName?: string; }
interface Props { items: Source[]; }
const { items } = Astro.props;
---

<section class="references-block" aria-labelledby="references-title">
  <header>
    <p>{currentLang === 'ru' ? 'Проверить самостоятельно' : 'Verify it yourself'}</p>
    <h2 id="references-title">{currentLang === 'ru' ? 'Источники' : 'Sources'}</h2>
    <span>{String(items.length).padStart(2, '0')}</span>
  </header>
  <div class="references-list">
    {items.map((item) => (
      <a id={`ref-${item.id}`} href={item.url} target="_blank" rel="noopener noreferrer">
        <b>{String(item.id).padStart(2, '0')}</b>
        <span><strong>{item.title}</strong><small>{item.sourceName || new URL(item.url).hostname.replace('www.', '')}</small></span>
        <i aria-hidden="true">↗</i>
      </a>
    ))}
  </div>
</section>

<style>
  .references-block { max-width: none; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  header { position: relative; margin-bottom: 1.4rem; }
  header p { margin: 0 0 .45rem; color: var(--color-primary); font-size: .62rem; font-weight: 800; letter-spacing: .09em; text-transform: uppercase; }
  header h2 { margin: 0; color: var(--color-foreground); font-size: clamp(1.8rem,3vw,2.7rem); letter-spacing: -.045em; }
  header > span { position: absolute; right: 0; bottom: .2rem; color: var(--color-primary); font-family: ui-monospace,monospace; font-size: .7rem; }
  .references-list { display: grid; grid-template-columns: 1fr 1fr; gap: .65rem; }
  .references-list a { display: grid; grid-template-columns: 2rem minmax(0,1fr) 1.2rem; gap: .75rem; align-items: start; padding: 1rem; border: 1px solid var(--color-border); border-radius: 1rem; background: color-mix(in srgb,var(--color-card) 75%,transparent); color: var(--color-foreground); text-decoration: none; }
  .references-list a:hover { border-color: var(--color-primary); background: color-mix(in srgb,var(--color-primary) 7%,var(--color-card)); }
  .references-list b { color: var(--color-primary); font-family: ui-monospace,monospace; font-size: .67rem; }
  .references-list span { min-width: 0; }
  .references-list strong, .references-list small { display: block; }
  .references-list strong { font-size: .82rem; line-height: 1.45; }
  .references-list small { margin-top: .4rem; color: var(--color-muted-foreground); font-size: .65rem; overflow-wrap: anywhere; }
  .references-list i { color: var(--color-primary); font-style: normal; }
  @media (max-width:700px) { .references-list { grid-template-columns: 1fr; } }
</style>
