---
import TelegramIcon from '../icons/TelegramIcon.astro';

interface Props { lang?: 'ru' | 'en'; compact?: boolean; }
const { lang = 'ru', compact = false } = Astro.props;
const isRu = lang === 'ru';
---

<aside class:list={['telegram-note', { 'is-compact': compact }]}>
  <div class="telegram-note-mark" aria-hidden="true"><TelegramIcon /></div>
  <div class="telegram-note-copy">
    <p>Telegram / @rerowroslog</p>
    <h2>{isRu ? 'Канал про AI, разработку и проекты.' : 'A channel about AI, development, and projects.'}</h2>
    <div>
      {isRu
        ? 'Пишу о том, что можно собрать одному человеку, где AI действительно помогает, а где только создаёт ощущение работы. Иногда — про эксперименты с SEO, органическим трафиком и продвижением без бюджета.'
        : 'I write about what one person can build, where AI genuinely helps, and where it only creates the feeling of progress. Sometimes I cover experiments with SEO, organic traffic, and zero-budget growth.'}
    </div>
  </div>
  <a href="https://t.me/rerowroslog" target="_blank" rel="noopener noreferrer">
    <TelegramIcon /> {isRu ? 'Открыть Telegram-канал' : 'Open Telegram channel'} <span aria-hidden="true">↗</span>
  </a>
</aside>

<style>
  .telegram-note { display: grid; grid-template-columns: 4rem minmax(0,1fr) auto; gap: clamp(1.2rem,3vw,3rem); align-items: center; margin: 1.25rem 0; padding: clamp(1.5rem,3vw,2.5rem); border: 1px solid color-mix(in srgb,var(--color-primary) 28%,var(--color-border)); border-radius: 1.6rem 3rem 1.6rem 3rem; background: color-mix(in srgb,var(--color-primary) 7%,var(--color-card)); }
  .telegram-note-mark { display: grid; width: 4rem; height: 4rem; place-items: center; border-radius: 1.3rem; background: var(--color-primary); color: var(--color-primary-foreground); transform: rotate(-4deg); }
  .telegram-note-mark :global(svg) { width: 1.6rem; height: 1.6rem; }
  .telegram-note-copy > p { margin: 0 0 .45rem; color: var(--color-primary); font-size: .64rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .telegram-note-copy h2 { margin: 0 0 .45rem; font-size: clamp(1.25rem,2vw,1.8rem); letter-spacing: -.035em; }
  .telegram-note-copy > div { max-width: 54rem; color: var(--color-muted-foreground); font-size: .88rem; line-height: 1.6; }
  .telegram-note > a { display: inline-flex; gap: .6rem; align-items: center; padding: 1rem 1.25rem; border: 1px solid var(--color-primary); border-radius: 1rem; background: var(--color-primary); color: var(--color-primary-foreground); box-shadow: 0 12px 30px color-mix(in srgb,var(--color-primary) 22%,transparent); font-size: .86rem; font-weight: 850; white-space: nowrap; transition: transform 180ms ease, box-shadow 180ms ease; }
  .telegram-note > a :global(svg) { width: 1.15rem; height: 1.15rem; }
  .telegram-note > a:hover { transform: translateY(-2px); box-shadow: 0 16px 36px color-mix(in srgb,var(--color-primary) 30%,transparent); }
  .telegram-note.is-compact { grid-template-columns: 2.8rem 1fr; border-radius: 1.3rem; }
  .telegram-note.is-compact .telegram-note-mark { width: 2.8rem; height: 2.8rem; }
  .telegram-note.is-compact > a { grid-column: 1/-1; justify-content: center; }
  @media (max-width:720px) { .telegram-note { grid-template-columns: 3rem 1fr; border-radius: 1.5rem; } .telegram-note-mark { width: 3rem; height: 3rem; } .telegram-note > a { grid-column: 1/-1; justify-content: center; } }
</style>
