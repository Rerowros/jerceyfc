---
// src/components/Contact.astro
import TelegramIcon from '../../components/icons/TelegramIcon.astro';

const currentLang = Astro.currentLocale || 'ru';
---

<section id="contact" class="flex flex-col items-center justify-center gap-6 text-center">
  <h2 class="text-foreground mb-2 text-4xl font-extrabold tracking-tight md:text-5xl">
    {currentLang === 'ru' ? 'Давайте работать вместе' : "Let's build something great"}
  </h2>
  <p class="text-muted-foreground mb-4 max-w-xl text-lg">
    {
      currentLang === 'ru' ? (
        <>
          У вас есть идея для проекта? Я открыт для предложений и готов помочь в ее реализации.
          Самый быстрый способ связаться — через Telegram.
        </>
      ) : (
        <>
          Have a project in mind? I'm open to opportunities and ready to help bring your ideas to
          life. The fastest way to reach me is on Telegram.
        </>
      )
    }
  </p>

  <!-- Main CTA with emphasis on Telegram -->
  <a href="https://t.me/Rerowros" target="_blank" rel="noopener noreferrer" class="btn">
    <TelegramIcon class="h-6 w-6" />
    {currentLang === 'ru' ? 'Написать в Telegram' : 'Contact me on Telegram'}
  </a>
</section>
