---
const currentLang = Astro.currentLocale || 'ru';
---

<footer class="site-footer">
  <div>
    <span>© {new Date().getFullYear()} Rerowros</span>
    <p>{currentLang === 'ru' ? 'Разработка, наблюдения и работа над деталями.' : 'Development, observation, and care for details.'}</p>
    <nav aria-label={currentLang === 'ru' ? 'Социальные ссылки' : 'Social links'}>
      <a href="https://github.com/Rerowros" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
      <a href="https://t.me/Rerowros" target="_blank" rel="noopener noreferrer">Telegram ↗</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    width: min(calc(100% - clamp(1rem, 3vw, 3rem)), 1800px);
    margin: 0 auto;
    padding: 0 0 1rem;
  }

  .site-footer > div {
    display: grid;
    grid-template-columns: 1fr 2fr auto;
    gap: 2rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 11%, transparent);
    border-radius: 1.4rem;
    background: color-mix(in srgb, var(--color-card) 78%, transparent);
    color: var(--color-muted-foreground);
    font-size: 0.75rem;
  }

  .site-footer p { margin: 0; text-align: center; }
  .site-footer nav { display: flex; gap: 1rem; }
  .site-footer a {
    padding: 0.2rem 0.45rem;
    border-radius: 0.55rem;
    color: var(--color-foreground);
    transition: color 150ms ease, background-color 150ms ease;
  }
  .site-footer a:hover {
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .site-footer { width: min(100% - 1.5rem, 1280px); }
    .site-footer > div { grid-template-columns: 1fr; gap: 0.75rem; }
    .site-footer p { text-align: left; }
  }
</style>
