---
import { getRelativeLocaleUrl } from 'astro:i18n';

const currentLang = Astro.currentLocale || 'ru';
const targetLang = currentLang === 'ru' ? 'en' : 'ru';
const currentPath = Astro.url.pathname.replace(/^\/en/, '') || '/';
const targetPath = getRelativeLocaleUrl(targetLang, currentPath);
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';

const links = [
  { href: getRelativeLocaleUrl(currentLang, 'projects/'), ru: 'Проекты', en: 'Projects' },
  { href: getRelativeLocaleUrl(currentLang, 'blog/'), ru: 'Блог', en: 'Writing' },
  { href: getRelativeLocaleUrl(currentLang, 'about/'), ru: 'Обо мне', en: 'About' },
];

const isCurrentPage = (href: string) => {
  const path = href.split('#')[0].replace(/\/+$/, '') || '/';
  return path !== '/' && (pathname === path || pathname.startsWith(`${path}/`));
};

const palettes = [
  ['indigo', '#818cf8', 'Indigo'],
  ['lavender', '#c084fc', 'Lavender'],
  ['mint', '#34d399', 'Mint'],
  ['sunny', '#fbbf24', 'Sunny'],
  ['rose', '#fb7185', 'Rose'],
];
---

<header class="site-header" data-site-header transition:name="site-header" transition:animate="none">
  <div class="site-header-inner">
    <a class="site-wordmark" href={getRelativeLocaleUrl(currentLang, '/')} aria-label="Rerowros">
      <span class="site-wordmark-orbit" aria-hidden="true"></span>
      <span class="site-wordmark-text" aria-hidden="true">Rerowros</span>
    </a>

    <nav class="site-nav" aria-label={currentLang === 'ru' ? 'Основная навигация' : 'Main navigation'}>
      {links.map((link) => (
        <a
          href={link.href}
          class:list={{ 'is-active': isCurrentPage(link.href) }}
          aria-current={isCurrentPage(link.href) ? 'page' : undefined}
        >{currentLang === 'ru' ? link.ru : link.en}</a>
      ))}
    </nav>

    <div class="site-controls">
      <div class="palette-control">
        <button id="palette-toggle" class="site-control palette-toggle" type="button" aria-expanded="false" aria-controls="palette-popover" aria-label={currentLang === 'ru' ? 'Выбрать цвет' : 'Choose color'}>
          <span></span><span></span><span></span>
        </button>
        <div id="palette-popover" class="palette-popover" hidden>
          <p>{currentLang === 'ru' ? 'Настроение' : 'Mood'}</p>
          <div class="palette-swatches">
            {palettes.map(([value, color, label]) => (
              <button type="button" data-palette={value} title={label} aria-label={label} style={`--swatch:${color}`}></button>
            ))}
          </div>
          <div class="byte-setting">
            <span>
              <b>{currentLang === 'ru' ? 'Байт' : 'Byte'}</b>
              <small>{currentLang === 'ru' ? 'Персонаж сайта' : 'Site companion'}</small>
            </span>
            <button
              id="byte-toggle"
              class="byte-switch"
              type="button"
              role="switch"
              aria-checked="true"
              aria-label={currentLang === 'ru' ? 'Показывать Байта' : 'Show Byte'}
            ><span></span></button>
          </div>
        </div>
      </div>

      <a class="site-control site-language" href={targetPath} aria-label="Switch language">
        {currentLang === 'ru' ? 'EN' : 'RU'}
      </a>
      <button id="theme-toggle" class="site-control" type="button" aria-label={currentLang === 'ru' ? 'Сменить тему' : 'Toggle theme'}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3a9 9 0 1 0 9 9c0-.5-.04-1-.12-1.48A7 7 0 0 1 13.5 3.16 9.5 9.5 0 0 0 12 3Z" />
        </svg>
      </button>
      <button id="site-menu-toggle" class="site-menu-toggle" type="button" aria-expanded="false" aria-controls="site-mobile-menu">
        <span></span><span></span>
        <span class="sr-only">{currentLang === 'ru' ? 'Открыть меню' : 'Open menu'}</span>
      </button>
    </div>
  </div>

  <div id="site-mobile-menu" class="site-mobile-menu" hidden>
    <nav aria-label={currentLang === 'ru' ? 'Мобильная навигация' : 'Mobile navigation'}>
      {links.map((link, index) => (
        <a
          href={link.href}
          class:list={{ 'is-active': isCurrentPage(link.href) }}
          aria-current={isCurrentPage(link.href) ? 'page' : undefined}
        ><span>0{index + 1}</span>{currentLang === 'ru' ? link.ru : link.en}</a>
      ))}
    </nav>
  </div>
</header>

<style is:inline>
  .site-header {
    position: fixed;
    top: 0.8rem;
    right: 0;
    left: 0;
    z-index: 50;
    width: min(calc(100% - clamp(1rem, 3vw, 3rem)), 1800px);
    margin: 0 auto;
    pointer-events: none;
  }

  .site-header-inner {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: clamp(0.45rem, 1vw, 0.8rem);
    align-items: center;
  }

  .site-wordmark,
  .site-nav,
  .site-controls {
    pointer-events: auto;
    min-height: 3.8rem;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 12%, transparent);
    background: color-mix(in srgb, var(--color-background) 84%, transparent);
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.13);
    backdrop-filter: blur(14px);
  }

  .site-wordmark {
    display: inline-flex;
    gap: 0.65rem;
    align-items: center;
    padding: 0 1.15rem;
    border-radius: 1.25rem 1.85rem 1.25rem 1.6rem;
    color: var(--color-foreground);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    transition: border-radius 700ms cubic-bezier(0.16, 1, 0.3, 1), background-color 240ms ease;
  }

  .site-wordmark:hover { border-radius: 1.9rem 1.25rem 1.9rem 1.25rem; background: color-mix(in srgb, var(--color-primary) 7%, var(--color-background)); }

  .site-wordmark-text { display: inline-block; }

  .site-wordmark-orbit {
    position: relative;
    width: 1.25rem;
    height: 1.25rem;
    flex: none;
    border: 2px solid var(--color-primary);
    border-radius: 48% 52% 50% 50% / 52% 48% 52% 48%;
    transform: rotate(0deg) scale(1);
    will-change: transform, border-radius;
  }

  .site-nav {
    display: flex;
    gap: 0.25rem;
    justify-self: center;
    min-height: auto;
    padding: 0.35rem;
    border-radius: 1.55rem 1.2rem 1.55rem 1.2rem;
  }

  .site-nav a {
    padding: 0.58rem 0.85rem;
    border-radius: 999px;
    color: var(--color-muted-foreground);
    font-size: 0.8rem;
    font-weight: 700;
    transition: color 160ms ease, background-color 160ms ease, transform 160ms ease;
  }

  .site-nav a:hover {
    background: color-mix(in srgb, var(--color-primary) 13%, transparent);
    color: var(--color-foreground);
    transform: translateY(-1px);
  }

  .site-nav a.is-active {
    background: color-mix(in srgb, var(--color-primary) 18%, var(--color-card));
    color: var(--color-foreground);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-primary) 24%, transparent);
  }

  .site-controls {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    min-height: auto;
    padding: 0.35rem;
    border-radius: 1.2rem 1.7rem 1.35rem 1.55rem;
  }

  .site-control,
  .site-menu-toggle {
    display: inline-flex;
    width: 2.35rem;
    height: 2.35rem;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 13%, transparent);
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--color-card) 80%, transparent);
    color: var(--color-foreground);
    font-size: 0.7rem;
    font-weight: 800;
    cursor: pointer;
    transition: transform 160ms ease, border-color 160ms ease, background-color 160ms ease;
  }

  .site-control:hover,
  .site-menu-toggle:hover {
    border-color: color-mix(in srgb, var(--color-primary) 55%, transparent);
    background: color-mix(in srgb, var(--color-primary) 12%, var(--color-card));
    transform: translateY(-2px) rotate(-2deg);
  }

  .site-control svg { width: 1rem; fill: currentColor; }
  .palette-control { position: relative; }

  .palette-toggle { gap: 2px; }
  .palette-toggle span { width: 4px; height: 13px; border-radius: 99px; background: var(--color-primary); }
  .palette-toggle span:nth-child(2) { height: 8px; opacity: 0.7; }
  .palette-toggle span:nth-child(3) { height: 5px; opacity: 0.45; }

  .palette-popover {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    width: 12.5rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    background: var(--color-card);
    box-shadow: 0 18px 55px rgba(0, 0, 0, 0.24);
  }

  .palette-popover p {
    margin: 0 0 0.75rem;
    color: var(--color-muted-foreground);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .palette-swatches { display: flex; gap: 0.5rem; }
  .palette-swatches button {
    width: 1.65rem;
    height: 1.65rem;
    border: 3px solid var(--color-card);
    border-radius: 50%;
    outline: 1px solid color-mix(in srgb, var(--color-foreground) 14%, transparent);
    background: var(--swatch);
    cursor: pointer;
    transition: transform 150ms ease, outline-color 150ms ease;
  }
  .palette-swatches button:hover,
  .palette-swatches button.is-active { transform: scale(1.16); outline-color: var(--color-foreground); }

  .byte-setting {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.9rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--color-border);
  }

  .byte-setting > span { display: flex; flex-direction: column; gap: 0.05rem; }
  .byte-setting b { color: var(--color-foreground); font-size: 0.78rem; }
  .byte-setting small { color: var(--color-muted-foreground); font-size: 0.62rem; }

  .byte-switch {
    position: relative;
    width: 2.65rem;
    height: 1.5rem;
    padding: 0;
    border: 1px solid color-mix(in srgb, var(--color-primary) 45%, var(--color-border));
    border-radius: 999px;
    background: var(--color-primary);
    cursor: pointer;
    transition: background-color 160ms ease, border-color 160ms ease;
  }

  .byte-switch span {
    position: absolute;
    top: 0.19rem;
    left: 1.3rem;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
    transition: left 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .byte-switch[aria-checked='false'] {
    border-color: var(--color-border);
    background: var(--color-muted);
  }

  .byte-switch[aria-checked='false'] span { left: 0.25rem; }

  .site-menu-toggle { display: none; flex-direction: column; gap: 5px; }
  .site-menu-toggle > span:not(.sr-only) { width: 14px; height: 1.5px; border-radius: 2px; background: currentColor; transition: transform 150ms ease; }
  .site-menu-toggle[aria-expanded='true'] > span:first-child { transform: translateY(3px) rotate(45deg); }
  .site-menu-toggle[aria-expanded='true'] > span:nth-child(2) { transform: translateY(-3px) rotate(-45deg); }

  .site-mobile-menu {
    pointer-events: auto;
    margin: 0.1rem 0.75rem 0.75rem;
    padding: 0.75rem;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-card) 80%, transparent);
  }
  .site-mobile-menu nav { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.45rem; }
  .site-mobile-menu a {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    padding: 0.85rem;
    border-radius: 0.85rem;
    background: color-mix(in srgb, var(--color-background) 55%, transparent);
    color: var(--color-foreground);
    font-size: 0.95rem;
    font-weight: 700;
  }
  .site-mobile-menu a span { color: var(--color-primary); font-family: ui-monospace, monospace; font-size: 0.6rem; }
  .site-mobile-menu a.is-active { background: color-mix(in srgb, var(--color-primary) 16%, var(--color-background)); }

  @media (max-width: 880px) {
    .site-nav { display: none; }
    .site-header-inner { grid-template-columns: minmax(0, 1fr) auto; }
    .site-wordmark { width: fit-content; }
    .site-menu-toggle { display: inline-flex; }
  }

  @media (max-width: 520px) {
    .site-header { width: calc(100% - 1rem); top: 0.5rem; }
    .site-wordmark,
    .site-controls { min-height: 3.45rem; }
    .site-wordmark { padding: 0 0.85rem; }
    .site-language { display: none; }
    .site-mobile-menu nav { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-wordmark-orbit,
    .site-wordmark,
    .site-nav a,
    .site-control,
    .palette-swatches button,
    .byte-switch,
    .byte-switch span { transition: none; }
  }
</style>

<script>
  function initPlayfulHeader() {
    const header = document.querySelector<HTMLElement>('[data-site-header]');
    if (!header || header.dataset.ready === 'true') return;
    header.dataset.ready = 'true';

    const menuButton = header.querySelector<HTMLElement>('#site-menu-toggle');
    const menu = header.querySelector<HTMLElement>('#site-mobile-menu');
    const themeButton = header.querySelector<HTMLElement>('#theme-toggle');
    const paletteButton = header.querySelector<HTMLElement>('#palette-toggle');
    const palette = header.querySelector<HTMLElement>('#palette-popover');
    const byteToggle = header.querySelector<HTMLButtonElement>('#byte-toggle');
    const wordmark = header.querySelector<HTMLElement>('.site-wordmark');
    const orbit = wordmark?.querySelector<HTMLElement>('.site-wordmark-orbit');

    if (wordmark && orbit && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      let motionGeneration = 0;
      let isSettling = false;
      let orbitAnimation: Animation | null = null;
      const randomBetween = (min: number, max: number) => min + Math.random() * (max - min);
      const randomRadius = () => {
        const values = Array.from({ length: 8 }, () => Math.round(randomBetween(40, 60)));
        return `${values.slice(0, 4).join('% ')}% / ${values.slice(4).join('% ')}%`;
      };

      const keepOrbitState = (animation: Animation) => {
        try {
          animation.commitStyles();
        } catch {
          const current = getComputedStyle(orbit);
          orbit.style.transform = current.transform;
          orbit.style.borderRadius = current.borderRadius;
        }
        animation.cancel();
      };

      const animateOrbit = (generation: number) => {
        if (!wordmark.isConnected || isSettling || generation !== motionGeneration) return;
        const current = getComputedStyle(orbit);
        orbitAnimation = orbit.animate(
          [
            { transform: current.transform, borderRadius: current.borderRadius },
            {
              transform: `rotate(${randomBetween(-24, 24).toFixed(2)}deg) scale(${randomBetween(0.96, 1.045).toFixed(3)})`,
              borderRadius: randomRadius(),
            },
          ],
          {
            duration: randomBetween(1800, 4200),
            easing: 'cubic-bezier(.42,.02,.3,.98)',
            fill: 'forwards',
          }
        );
        const currentAnimation = orbitAnimation;
        void currentAnimation.finished.then(() => {
          if (generation !== motionGeneration || isSettling) return;
          keepOrbitState(currentAnimation);
          animateOrbit(generation);
        }).catch(() => undefined);
      };

      const startOrbit = () => {
        const generation = ++motionGeneration;
        isSettling = false;
        animateOrbit(generation);
      };

      wordmark.addEventListener('pointerenter', () => {
        motionGeneration += 1;
        isSettling = true;
        const current = getComputedStyle(orbit);
        orbitAnimation?.cancel();
        orbitAnimation = orbit.animate(
          [
            { transform: current.transform, borderRadius: current.borderRadius },
            { transform: 'rotate(0deg) scale(1)', borderRadius: '50%' },
          ],
          { duration: 950, easing: 'cubic-bezier(.16,1,.3,1)', fill: 'forwards' }
        );
      });

      wordmark.addEventListener('pointerleave', () => {
        if (orbitAnimation) keepOrbitState(orbitAnimation);
        startOrbit();
      });

      startOrbit();
    }

    if (menuButton && menu) {
      menuButton.onclick = () => {
        const isOpen = menuButton.getAttribute('aria-expanded') === 'true';
        menuButton.setAttribute('aria-expanded', String(!isOpen));
        menu.hidden = isOpen;
      };
      menu.querySelectorAll('a').forEach((link) => {
        (link as HTMLAnchorElement).onclick = () => {
          menu.hidden = true;
          menuButton.setAttribute('aria-expanded', 'false');
        };
      });
    }

    if (themeButton) {
      themeButton.onclick = () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
      };
    }

    if (byteToggle) {
      const applyByteState = (enabled: boolean, notify = true) => {
        byteToggle.setAttribute('aria-checked', String(enabled));
        document.documentElement.dataset.byteEnabled = String(enabled);
        localStorage.setItem('byte-enabled', String(enabled));
        if (notify) {
          window.dispatchEvent(new CustomEvent('byte:toggle', { detail: { enabled } }));
        }
      };

      applyByteState(localStorage.getItem('byte-enabled') !== 'false', false);
      byteToggle.onclick = () => {
        applyByteState(byteToggle.getAttribute('aria-checked') !== 'true');
      };
    }

    if (paletteButton && palette) {
      const buttons = palette.querySelectorAll<HTMLElement>('[data-palette]');
      const updateActive = () => {
        const active = document.documentElement.dataset.theme || 'indigo';
        buttons.forEach((button) => button.classList.toggle('is-active', button.dataset.palette === active));
      };
      updateActive();
      paletteButton.onclick = () => {
        const isOpen = paletteButton.getAttribute('aria-expanded') === 'true';
        paletteButton.setAttribute('aria-expanded', String(!isOpen));
        palette.hidden = isOpen;
      };
      buttons.forEach((button) => {
        button.onclick = () => {
          const value = button.dataset.palette;
          if (!value) return;
          document.documentElement.dataset.theme = value;
          localStorage.setItem('palette', value);
          updateActive();
        };
      });
    }
  }

  document.addEventListener('astro:page-load', initPlayfulHeader);
</script>
